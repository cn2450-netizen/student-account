# Application
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# PostgreSQL credentials (Docker local dev)
# These are generated automatically by: npm run db:setup-creds
# Do NOT use these placeholder values — run db:init and let the script generate real ones.
POSTGRES_USER=student
POSTGRES_PASSWORD=change-me

# Connection string — kept in sync with POSTGRES_USER/POSTGRES_PASSWORD by setup-dev-env.mjs
DATABASE_URL=postgresql://student:change-me@localhost:5432/student_account?schema=public
