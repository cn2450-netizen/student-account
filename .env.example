# Application
NEXTAUTH_URL=https://your-server-hostname-or-ip
NEXTAUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars

# PostgreSQL connection string
# The install script generates this automatically and writes it to .env.
# If setting up manually, replace <password> with the DB user's password.
DATABASE_URL=postgresql://moneyfinder_app:<password>@localhost:5432/moneyfinder?schema=public
